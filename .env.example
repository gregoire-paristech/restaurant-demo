# ─── Backend LLM (compatible OpenAI) ────────────────────────────────────────
# URL de base de l'API — pointe vers Ollama en local par défaut
LLM_BASE_URL=http://localhost:11434/v1

# Clé API — "ollama" suffit pour Ollama local
# Pour Together AI / Groq / OpenRouter, mets ta vraie clé ici
LLM_API_KEY=ollama

# Modèle de chat (doit être pullé dans Ollama : `ollama pull qwen2.5:7b`)
LLM_CHAT_MODEL=qwen2.5:7b

# Modèle d'embedding (optionnel — uniquement si tu utilises /api/ai/embed)
LLM_EMBED_MODEL=nomic-embed-text

# Timeout des requêtes en millisecondes (Ollama local peut être plus lent au 1er appel)
LLM_TIMEOUT_MS=60000

# ─── Alternatives hébergées (décommenter et remplacer LLM_* ci-dessus) ───────
# Together AI  → LLM_BASE_URL=https://api.together.xyz/v1
#                LLM_CHAT_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
#                LLM_API_KEY=<ta-clé-together>
#
# Groq         → LLM_BASE_URL=https://api.groq.com/openai/v1
#                LLM_CHAT_MODEL=qwen-qwq-32b
#                LLM_API_KEY=<ta-clé-groq>

# ─── Serveur Express ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Origines autorisées en production (séparées par virgule)
# ALLOWED_ORIGIN=https://ton-domaine.com
